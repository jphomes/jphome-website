# Server
PORT=5000
NODE_ENV=development
# Which DB to use locally/on server: stage | prod
APP_ENV=stage

# Frontend origin(s) allowed by CORS — comma-separated for www + apex
CLIENT_URL=http://localhost:5173

# MongoDB Atlas
# Get this from Atlas → Connect → Drivers → Node.js (includes host + user + password)
MONGO_URI_STAGE=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/jpgroup_stage?retryWrites=true&w=majority
MONGO_URI_PROD=

# Auth (single admin)
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
ADMIN_USERNAME=jpadmin
ADMIN_EMAIL=website.jphomes@gmail.com
ADMIN_PASSWORD=ChangeMe123!

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=jpgroup

# Mail (optional — enquiries)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user@gmail.com
SMTP_PASS=your_smtp_app_password
MAIL_FROM="JP Group Raipur" <no-reply@yourdomain.com>
ADMIN_NOTIFY_EMAIL=website.jphomes@gmail.com
