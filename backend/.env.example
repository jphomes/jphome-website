# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/sondagar_estates

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# The ONLY admin account allowed to log in and post blogs/properties.
# Set a real password before running "npm run seed:admin".
ADMIN_USERNAME=sondagartom
ADMIN_EMAIL=tom@sondagarestates.com
ADMIN_PASSWORD=ChangeMe123!

# Mail (SMTP) - used to send the enquiry template + notify the admin
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user@gmail.com
SMTP_PASS=your_smtp_app_password
MAIL_FROM="Sondagar Estates" <no-reply@sondagarestates.com>
ADMIN_NOTIFY_EMAIL=tom@sondagarestates.com
